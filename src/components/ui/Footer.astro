---
import { footerNavigationData } from '../../config/footerNavigation'

const { footerAbout, footerColumns, subFooter } = footerNavigationData
---

<footer class="footer">
	<div class="footer__main">
		<div class="footer__container">
			<div class="footer__cols">
				<div class="footer__col">
					<a aria-label="website logo" aria-current="page" class="footer__main-brand" href="/">
						<img src={footerAbout.logo.src} alt={footerAbout.logo.alt} width="24" height="24" />
						{footerAbout.logo.text}
					</a>
					<p>{footerAbout.aboutText}</p>
				</div>
				{
					footerColumns.map((column) => (
						<div class="footer__col">
							<h3>{column.category}</h3>
							<ul>
								{column.subCategories.map((subCategory) => (
									<li>
										<a href={subCategory.subCategoryLink} target="_blank" rel="noreferrer">
											{subCategory.subCategory}
										</a>
									</li>
								))}
							</ul>
						</div>
					))
				}
			</div>
		</div>
	</div>
	<div class="footer__sub">
		<div class="footer__container">
			<div class="footer__sub-cols">
				<div class="footer__sub-col">{subFooter.copywriteText}</div>
			</div>
		</div>
	</div>
</footer>

<style>
	.footer {
		@apply text-neutral-300;
	}
	.footer a {
		@apply transition-colors duration-300 hover:text-primary-500 focus:text-primary-600;
	}
	.footer__main {
		@apply border-t border-neutral-900 bg-neutral-950 pb-12 pt-16 text-sm [&_li]:mb-2 [&_li]:leading-6;
	}
	.footer__main h3 {
		@apply mb-6 text-base font-medium leading-8 text-neutral-50;
	}
	.footer__main-brand {
		@apply mb-6 flex items-center gap-2 whitespace-nowrap font-headings text-xl font-semibold tracking-[0.2em] leading-6 text-primary-500 focus:outline-none;
	}
	.footer__container {
		@apply container mx-auto px-6;
	}
	.footer__cols {
		@apply grid grid-cols-1 gap-10 md:grid-cols-2;
	}
	.footer__sub {
		@apply border-t border-neutral-900 bg-neutral-900/50 py-4 text-sm text-neutral-400;
	}
	.footer__sub-cols {
		@apply grid grid-cols-1 items-center gap-6;
	}
</style>
